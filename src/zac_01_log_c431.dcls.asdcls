@EndUserText.label: 'Access control - Literal'
@MappingRole: true
define role ZAC_01_LOG_C431 {
    grant
        select
            on
                zcds_08_log_c431
                    where
                        CountryCode = 'ES';
                        
    grant select on zcds_09_log_c431
    where status = 'N';                    
                        
}